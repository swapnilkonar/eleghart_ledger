  "WealthRepository": {
    "file": "lib/services/wealth_repository.dart",
    "type": "class (all static)",
    "methods": [
      "loadGoals()→Future<List<WealthGoal>> — ordered by created_at DESC",
      "insertGoal(WealthGoal)→Future<void>",
      "updateGoal(WealthGoal)→Future<void> — updates by id, preserves currentAmount",
      "deleteGoal(String id)→Future<void> — transaction: deletes contributions then goal",
      "loadContributions(String goalId)→Future<List<WealthContribution>> — ordered by contribution_date DESC",
      "addContribution({goal, amount, date, notes})→Future<WealthGoal> — amount clamped to 0, returns updatedGoal",
      "deleteContribution(WealthContribution, WealthGoal)→Future<WealthGoal> — reverses amount effect",
      "generateId()→String — Uuid().v4()"
    ],
    "note": "addContribution: newAmount = (currentAmount + amount).clamp(0, ∞). Debit stored as negative amount."
  },

  "WealthService": {
    "file": "lib/services/wealth_service.dart",
    "type": "class (all static)",
    "methods": [
      "calculateHealth(WealthGoal)→GoalHealth — calls expectedSaved(), ratio check",
      "calculateMonthlyRequired(WealthGoal)→double — remaining / monthsLeft",
      "elapsedMonths(WealthGoal)→int — months since createdAt",
      "remainingMonths(WealthGoal)→int — months until targetDate",
      "totalMonths(WealthGoal)→int — total duration in months (min 1)",
      "expectedSaved(WealthGoal)→double — month-based, min 1 elapsed month so always non-zero for new goals",
      "gap(WealthGoal)→double — max(0, expectedSaved - currentAmount)",
      "coachMessage(WealthGoal)→String — AI coach text based on health",
      "formatAmount(double)→String — compact: ₹1.2K, ₹1.2L, ₹1.2Cr",
      "formatAmountFull(double)→String — full: ₹1.20L, ₹1.20Cr"
    ],
    "note": "expectedSaved uses max(1, elapsedMonths) so brand-new goals always show first month's target, never ₹0."
  },

